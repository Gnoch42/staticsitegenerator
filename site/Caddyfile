# cv-site — serves only the static files from the shared volume.
# External HTTP routing (domain, TLS) is handled by Traefik/Coolify;
# here Caddy simply listens over HTTP on :80 internally.

:80 {
	root * /data/site
	encode gzip zstd
	file_server

	# "Clean" URLs: /cv -> /cv/index.html
	try_files {path} {path}/ {path}/index.html

	# If the site has not been published yet, show a clear message
	# instead of a raw 404.
	handle_errors {
		@notpublished expression {http.error.status_code} == 404
		respond @notpublished "Site not published yet. Open the admin and click \"Publish\"." 200
	}
}
