# ─────────────────────────────────────────────────────────────
#  cv-generator / cv-site — environment variables
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` (local) or set these values in the
# Coolify UI of each resource.

# ── Admin authentication ─────────────────────────────────────
# bcrypt hash of the admin password (NOT the plaintext password).
# Generate with:  node generator/scripts/hash-password.mjs "myPassword"
#
# ⚠️  GOTCHA — the `$` character
#   • In a .env / .env.local FILE (local dev): Next interprets `$`,
#     which CORRUPTS the bcrypt hash. Escape every `$` as `\$`:
#       ADMIN_PASSWORD_HASH=\$2b\$12\$abcd...   (local file only)
#   • In the COOLIFY UI (or any shell `export` in single quotes):
#     paste the RAW hash, with no `\`:
#       ADMIN_PASSWORD_HASH=$2b$12$abcd...
ADMIN_PASSWORD_HASH=$2b$12$replace_this_with_a_real_bcrypt_hash_value_here

# Secret used to sign the session cookie (HMAC).
# Generate with:  openssl rand -hex 32
SESSION_SECRET=replace_with_a_long_random_hex_string

# ── Storage (shared volume) ──────────────────────────────────
# Directory mounted on the Docker volume shared between both services.
# Holds the SQLite database, the published static files and uploads.
DATA_DIR=/data

# Path to the SQLite file (derived from DATA_DIR by default).
DATABASE_PATH=/data/cv.db

# Directory the "Publish" button writes the static site to, and that
# Caddy serves. Must live under DATA_DIR (shared volume).
SITE_OUTPUT_DIR=/data/site

# Directory for uploaded images (portfolio, profile photo). Optional:
# defaults to <dir of DATABASE_PATH>/uploads, so already in the volume.
# Copied into SITE_OUTPUT_DIR on publish.
# UPLOADS_DIR=/data/uploads

# ── Internal network ─────────────────────────────────────────
# Internal port of the Next.js service (cv-generator). Coolify/Traefik
# route to this port via labels — no hard-coded port mapping.
PORT=3000

# Internal URL used by Playwright to render the CV PDF
# (must point to the app itself, locally inside the container).
INTERNAL_BASE_URL=http://127.0.0.1:3000
