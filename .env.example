# ─────────────────────────────────────────────────────────────
#  cv-generator / cv-site — variables d'environnement
# ─────────────────────────────────────────────────────────────
# Copiez ce fichier en `.env` (local) ou renseignez ces valeurs
# dans l'interface Coolify de chaque ressource.

# ── Authentification admin ───────────────────────────────────
# Hash bcrypt du mot de passe admin (PAS le mot de passe en clair).
# Générer avec :  node generator/scripts/hash-password.mjs "monMotDePasse"
ADMIN_PASSWORD_HASH=$2b$12$replace_this_with_a_real_bcrypt_hash_value_here

# Secret utilisé pour signer le cookie de session (HMAC).
# Générer avec :  openssl rand -hex 32
SESSION_SECRET=replace_with_a_long_random_hex_string

# ── Stockage (volume partagé) ────────────────────────────────
# Répertoire monté sur le volume Docker partagé entre les 2 services.
# Contient la base SQLite et les fichiers statiques publiés.
DATA_DIR=/data

# Chemin du fichier SQLite (dérivé de DATA_DIR par défaut).
DATABASE_PATH=/data/cv.db

# Répertoire où le bouton "Publier" écrit le site statique,
# et que Caddy sert. Doit être sous DATA_DIR (volume partagé).
SITE_OUTPUT_DIR=/data/site

# ── Réseau interne ───────────────────────────────────────────
# Port interne du service Next.js (cv-generator). Coolify/Traefik
# route vers ce port via labels — pas de mapping de port en dur.
PORT=3000

# URL interne que Playwright utilise pour rendre le CV en PDF
# (doit pointer vers l'app elle-même, en local dans le conteneur).
INTERNAL_BASE_URL=http://127.0.0.1:3000
